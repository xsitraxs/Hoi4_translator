```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
pip-log.txt
pipenv.lock

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/
```
